models/ml/*.joblib
models/ml/*.h5
models/dl/*.h5
models/dl/*.pt
models/dl/*.pth
models/dl/*.ckpt
models/genai/*.bin
models/genai/*.safetensors
*.onnx

# Keep directory structure
!models/ml/.gitkeep
!models/dl/.gitkeep
!models/genai/.gitkeep

