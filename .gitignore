# ============================================================================
# Data Files (exclude large datasets from git)
# ============================================================================
data/raw/*.csv
data/raw/*.xlsx
data/raw/*.json
data/raw/*.parquet
data/processed/*.csv
data/processed/*.pkl
data/processed/*.parquet
data/processed/*.npy
data/external/*.csv
*.h5
*.hdf5

# Keep directory structure but ignore contents
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# ============================================================================
