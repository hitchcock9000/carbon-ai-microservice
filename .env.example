# ============================================================================
# Carbon Footprint AI Microservice - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Carbon Footprint AI Microservice
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
API_WORKERS=1

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://username:password@localhost:5432/carbon_ai_db
DB_ECHO=False

# SQLite (for development/testing)
# DATABASE_URL=sqlite:///./carbon_ai.db

# ============================================================================
# OpenAI API
# ============================================================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ============================================================================
#   API (Optional)
# ============================================================================
=your__api_key_here
=-3-opus-20240229

# ============================================================================
# Hugging Face (Optional)
# ============================================================================
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=meta-llama/Llama-2-7b-chat-hf

# ============================================================================
# Vector Database (ChromaDB)
# ============================================================================
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=carbon_knowledge

# ============================================================================
# Pinecone (Optional)
# ============================================================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=carbon-embeddings

# ============================================================================
# Speech Services (Optional)
# ============================================================================
# ElevenLabs for Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=default

# ============================================================================
# AWS Configuration (Optional)
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=carbon-ai-data

# ============================================================================
# Google Cloud Platform (Optional)
# ============================================================================
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GCP_PROJECT_ID=your_project_id
GCS_BUCKET_NAME=carbon-ai-data

# ============================================================================
# Azure (Optional)
# ============================================================================
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_CONTAINER_NAME=carbon-ai-data

# ============================================================================
# Security
# ============================================================================
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# CORS Settings
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
ALLOWED_METHODS=GET,POST,PUT,DELETE
ALLOWED_HEADERS=*

# ============================================================================
# Model Paths
# ============================================================================
ML_MODEL_PATH=./models/ml
DL_MODEL_PATH=./models/dl
GENAI_MODEL_PATH=./models/genai

# ============================================================================
# Data Paths
# ============================================================================
RAW_DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed
EXTERNAL_DATA_PATH=./data/external

# ============================================================================
# Monitoring & Logging
# ============================================================================
SENTRY_DSN=your_sentry_dsn_here
ENABLE_SENTRY=False

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_CHATBOT=True
ENABLE_VOICE_INTERFACE=False
ENABLE_IMAGE_ANALYSIS=True
ENABLE_REPORT_GENERATION=True

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Cache Configuration
# ============================================================================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# ============================================================================
# Tableau Configuration (Optional)
# ============================================================================
TABLEAU_SERVER_URL=https://your-tableau-server.com
TABLEAU_USERNAME=your_username
TABLEAU_PASSWORD=your_password
TABLEAU_SITE_ID=your_site_id
